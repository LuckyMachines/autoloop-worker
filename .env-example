# Global defaults used by all networks unless overridden.
PRIVATE_KEY=0x...
RPC_URL=http://127.0.0.1:8545

# RPC Failover — comma-separated URLs for automatic failover.
# The worker will try each URL in order if the current one fails.
# RPC_URL=https://primary.example.com,https://fallback1.example.com,https://fallback2.example.com

# Numbered RPC fallbacks — appended after comma-separated URLs.
# Useful when each URL comes from a different env var / secret.
# RPC_URL_1=https://fallback1.example.com
# RPC_URL_2=https://fallback2.example.com

# Network override (optional — overrides controller.config.json)
# NETWORK=anvil

# Health server port (optional, default 3000)
# PORT=3000

# Alert webhook (optional — Slack or generic HTTP endpoint).
# Slack:   https://hooks.slack.com/services/T.../B.../xxx
# Generic: https://your-server.com/alerts  (receives JSON POST)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Optional per-network overrides.
PRIVATE_KEY_ANVIL=0x...
RPC_URL_ANVIL=http://127.0.0.1:8545
PRIVATE_KEY_SEPOLIA=0x...
RPC_URL_SEPOLIA=https://ethereum-sepolia-rpc.publicnode.com

# Legacy aliases (still supported for backward compatibility).
PRIVATE_KEY_TESTNET=0x...
RPC_URL_TESTNET=https://ethereum-sepolia-rpc.publicnode.com
