# Global defaults used by all networks unless overridden.
PRIVATE_KEY=0x...
RPC_URL=http://127.0.0.1:8555

# Optional per-network overrides.
PRIVATE_KEY_ANVIL=0x...
RPC_URL_ANVIL=http://127.0.0.1:8555
